<!DOCTYPE html>
<%# Shows task and meeting matches from the selected project. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Results</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>
    <div class="container-fluid"><div class="row">
        <%- include("partials/sidebar") %>
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <%- include("partials/messages") %>
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                <div>
                    <h1 class="h2 mb-1">Search Results</h1>
                    <p class="text-muted mb-0"><%= totalResults %> result(s) for “<%= query %>”</p>
                </div>
                <a href="/dashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
            </div>

            <% if (totalResults === 0) { %>
                <div class="alert alert-info">No matching tasks or meetings were found.</div>
            <% } %>

            <% if (tasks.length > 0) { %>
                <section class="card mb-4">
                    <div class="card-header bg-white"><h2 class="h5 mb-0">Tasks</h2></div>
                    <div class="list-group list-group-flush">
                        <% tasks.forEach(function (task) { %>
                            <a href="/tasks/<%= task.taskId %>" class="list-group-item list-group-item-action p-3">
                                <div class="d-flex justify-content-between gap-3">
                                    <strong><%= task.taskName %></strong>
                                    <span class="badge text-bg-secondary"><%= task.status %></span>
                                </div>
                                <p class="text-muted mb-1"><%= task.description || "No description" %></p>
                                <small><%= task.priority %> priority - Due <%= new Date(task.dueDate).toLocaleDateString("en-SG") %></small>
                            </a>
                        <% }); %>
                    </div>
                </section>
            <% } %>

            <% if (meetings.length > 0) { %>
                <section class="card">
                    <div class="card-header bg-white"><h2 class="h5 mb-0">Meetings</h2></div>
                    <div class="list-group list-group-flush">
                        <% meetings.forEach(function (meeting) { %>
                            <a href="/meetings/<%= meeting.meetingId %>" class="list-group-item list-group-item-action p-3">
                                <strong><%= meeting.meetingTitle %></strong>
                                <p class="text-muted mb-1"><%= meeting.agenda || "No agenda" %></p>
                                <small><%= new Date(meeting.meetingDate).toLocaleDateString("en-SG") %> at <%= meeting.meetingTime %></small>
                            </a>
                        <% }); %>
                    </div>
                </section>
            <% } %>
        </main>
    </div></div>
    <%- include("partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
