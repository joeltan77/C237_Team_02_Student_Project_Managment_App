<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Calendar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <style>
        #calendar { max-width: 1150px; margin: 0 auto; }
        .fc-event { cursor: pointer; }
        .calendar-legend span { display: inline-block; width: .75rem; height: .75rem; border-radius: 50%; margin-right: .3rem; }
        .popover { max-width: 330px; }
        .popover-body { padding: 1rem; }
    </style>
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>
    <div class="container-fluid"><div class="row">
        <%- include("partials/sidebar") %>
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <%- include("partials/messages") %>
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                <div>
                    <h1 class="h2 mb-1">Project Calendar</h1>
                    <p class="text-muted mb-0">Task deadlines and meetings for <%= selectedProject.projectName %>.</p>
                </div>
                <div class="calendar-legend d-flex flex-wrap gap-3 small">
                    <div><span style="background:#dc3545"></span>High priority</div>
                    <div><span style="background:#fd7e14"></span>Medium priority</div>
                    <div><span style="background:#0d6efd"></span>Low priority</div>
                    <div><span style="background:#198754"></span>Completed</div>
                    <div><span style="background:#6f42c1"></span>Meeting</div>
                </div>
            </div>
            <div class="card border-0 shadow-sm"><div class="card-body"><div id="calendar"></div></div></div>
        </main>
    </div></div>
    <%- include("partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script id="calendar-data" type="application/json"><%- calendarEventsJson %></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const calendarData = document.getElementById("calendar-data").textContent;
            const events = JSON.parse(calendarData);
            let activePopover = null;
            let hideTimer = null;

            function escapeHtml(value) {
                return String(value || "").replace(/[&<>"']/g, character => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" }[character]));
            }

            function popoverContent(event) {
                const details = event.extendedProps;
                if (details.type === "task") {
                    return `<div class="small mb-2"><strong>Due task</strong></div>
                        <div class="mb-2">${escapeHtml(details.description)}</div>
                        <div class="small text-muted mb-3">Priority: ${escapeHtml(details.priority)}<br>Status: ${escapeHtml(details.status)}</div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-primary" href="/tasks/${details.taskId}">View</a>
                            <a class="btn btn-sm btn-outline-secondary" href="/tasks/${details.taskId}/edit">Edit</a>
                        </div>`;
                }
                return `<div class="small mb-2"><strong>Meeting</strong></div>
                    <div class="small text-muted mb-3">Time: ${escapeHtml(details.time)}<br>Location: ${escapeHtml(details.location)}</div>
                    <a class="btn btn-sm btn-primary" href="/meetings/${details.meetingId}">View</a>`;
            }

            function scheduleHide(popover) {
                clearTimeout(hideTimer);
                hideTimer = setTimeout(() => popover.hide(), 180);
            }

            const calendar = new FullCalendar.Calendar(document.getElementById("calendar"), {
                initialView: "dayGridMonth",
                height: "auto",
                events,
                eventDidMount: function (info) {
                    const popover = new bootstrap.Popover(info.el, {
                        title: escapeHtml(info.event.title),
                        content: popoverContent(info.event),
                        html: true,
                        sanitize: false,
                        trigger: "manual",
                        placement: "auto",
                        container: "body"
                    });

                    info.el.setAttribute("tabindex", "0");
                    const show = () => {
                        clearTimeout(hideTimer);
                        if (activePopover && activePopover !== popover) activePopover.hide();
                        activePopover = popover;
                        popover.show();
                        const tip = popover.tip;
                        if (tip) {
                            tip.addEventListener("mouseenter", () => clearTimeout(hideTimer));
                            tip.addEventListener("mouseleave", () => scheduleHide(popover));
                        }
                    };
                    info.el.addEventListener("mouseenter", show);
                    info.el.addEventListener("mouseleave", () => scheduleHide(popover));
                    info.el.addEventListener("focus", show);
                    info.el.addEventListener("blur", () => scheduleHide(popover));
                },
                eventClick: function (info) {
                    const details = info.event.extendedProps;
                    window.location.href = details.type === "task" ? `/tasks/${details.taskId}` : `/meetings/${details.meetingId}`;
                }
            });
            calendar.render();
        });
    </script>
</body>
</html>
