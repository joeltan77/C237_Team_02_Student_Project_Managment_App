<!DOCTYPE html>
<%# Lists project tasks with create, view and edit actions. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tasks</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>
    <div class="container-fluid">
        <div class="row">
            <%- include("partials/sidebar") %>
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                <%- include("partials/messages") %>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="h2 mb-1">Tasks</h1>
                        <p class="text-muted mb-0"><%= selectedProject.projectName %></p>
                    </div>
                    <a href="/addtask" class="btn btn-primary">Create Task</a>
                </div>

                <% if (tasks.length === 0) { %>
                    <div class="alert alert-info">No tasks have been created for this project.</div>
                <% } else { %>
                    <div class="card border-0 shadow-sm">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Task</th><th>Assigned To</th><th>Priority</th>
                                        <th>Status</th><th>Due Date</th><th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% tasks.forEach(function (task) { %>
                                        <tr>
                                            <td>
                                                <strong><%= task.taskName %></strong>
                                                <% if (task.description) { %><div class="small text-muted"><%= task.description %></div><% } %>
                                            </td>
                                            <td><%= task.assignedUserName %></td>
                                            <td><%= task.priority %></td>
                                            <td><%= task.status %></td>
                                            <td><%= new Date(task.dueDate).toLocaleDateString("en-SG") %></td>
                                            <td class="text-end">
                                                <a href="/tasks/<%= task.taskId %>" class="btn btn-sm btn-outline-primary">View</a>
                                                <a href="/tasks/<%= task.taskId %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } %>
            </main>
        </div>
    </div>
    <%- include("partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
