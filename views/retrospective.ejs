<%# Fast three-column retrospective board using one shared edit modal. %>
<%
    const buckets = [
        { title: "What Went Well", type: "went_well", colour: "success", items: wentWell },
        { title: "What Can Be Improved", type: "improvement", colour: "warning", items: improvements },
        { title: "Say Thanks", type: "thanks", colour: "primary", items: thanks }
    ];
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Retrospective Board</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>
    <div class="container-fluid">
        <div class="row">
            <%- include("partials/sidebar") %>
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                <%- include("partials/messages") %>

                <div class="mb-4">
                    <h1 class="h2 mb-1">Retrospective Board</h1>
                    <p class="text-muted mb-0">Reflect on the selected project's progress.</p>
                </div>

                <div class="row g-4">
                    <% buckets.forEach(function (bucket) { %>
                        <div class="col-lg-4">
                            <section class="card border-<%= bucket.colour %> shadow-sm h-100">
                                <div class="card-header text-bg-<%= bucket.colour %>">
                                    <h2 class="h5 mb-0 text-white"><%= bucket.title %></h2>
                                </div>
                                <div class="card-body">
                                    <form action="/retrospective/add" method="POST" class="mb-4">
                                        <input type="hidden" name="bucketType" value="<%= bucket.type %>">
                                        <textarea class="form-control mb-2" name="content" rows="3" maxlength="1000" placeholder="Write your reflection..." required></textarea>
                                        <button type="submit" class="btn btn-<%= bucket.colour %> w-100">Add Entry</button>
                                    </form>

                                    <% if (bucket.items.length === 0) { %>
                                        <div class="alert alert-light border">No entries yet.</div>
                                    <% } %>

                                    <% bucket.items.forEach(function (item) { %>
                                        <% const canManage = currentProjectRole === "Project Leader" || item.userId == currentUser.userId; %>
                                        <article class="card bg-light mb-3">
                                            <div class="card-body">
                                                <p class="mb-2"><%= item.content %></p>
                                                <p class="small text-muted mb-3">Added by <%= item.userName %></p>
                                                <% if (canManage) { %>
                                                    <div class="d-flex gap-2">
                                                        <button type="button" class="btn btn-sm btn-outline-primary edit-retrospective"
                                                            data-bs-toggle="modal" data-bs-target="#editRetrospectiveModal"
                                                            data-item-id="<%= item.retrospectiveId %>"
                                                            data-bucket-type="<%= item.bucketType %>"
                                                            data-content="<%= item.content %>">Edit</button>
                                                        <form action="/retrospective/<%= item.retrospectiveId %>/delete" method="POST" onsubmit="return confirm('Delete this entry?');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                        </form>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </article>
                                    <% }); %>
                                </div>
                            </section>
                        </div>
                    <% }); %>
                </div>
            </main>
        </div>
    </div>

    <%# One modal is reused for every entry instead of rendering a modal per card. %>
    <div class="modal fade" id="editRetrospectiveModal" tabindex="-1" aria-labelledby="editRetrospectiveTitle" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="editRetrospectiveForm" method="POST">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="editRetrospectiveTitle">Edit Entry</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="editBucketType" class="form-label">Bucket</label>
                            <select class="form-select" id="editBucketType" name="bucketType" required>
                                <option value="went_well">What Went Well</option>
                                <option value="improvement">What Can Be Improved</option>
                                <option value="thanks">Say Thanks</option>
                            </select>
                        </div>
                        <div>
                            <label for="editContent" class="form-label">Content</label>
                            <textarea class="form-control" id="editContent" name="content" rows="4" maxlength="1000" required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include("partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll(".edit-retrospective").forEach(function (button) {
            button.addEventListener("click", function () {
                document.getElementById("editRetrospectiveForm").action = "/retrospective/" + button.dataset.itemId + "/edit";
                document.getElementById("editBucketType").value = button.dataset.bucketType;
                document.getElementById("editContent").value = button.dataset.content;
            });
        });
    </script>
</body>
</html>
