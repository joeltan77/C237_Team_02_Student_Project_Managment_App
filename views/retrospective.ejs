<%# Builds the three retrospective columns from one reusable layout. %>
<%
    const buckets = [
        {
            title: "What Went Well",
            type: "went_well",
            colour: "success",
            items: wentWell
        },
        {
            title: "What Can Be Improved",
            type: "improvement",
            colour: "warning",
            items: improvements
        },
        {
            title: "Say Thanks",
            type: "thanks",
            colour: "primary",
            items: thanks
        }
    ];
%>

<!DOCTYPE html>
<%# Three-column board for project reflections. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Retrospective Board</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/resources/styles.css">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <div class="container-fluid">
        <div class="row">

            <%- include("partials/sidebar") %>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">

                <%- include("partials/messages") %>

                <div class="mb-4">
                    <h1 class="h2 mb-1">
                        Retrospective Board
                    </h1>

                    <p class="text-muted mb-0">
                        Reflect on the selected project's progress.
                    </p>
                </div>

                <div class="row g-4">

                    <% buckets.forEach(function (bucket) { %>
                        <div class="col-lg-4">

                            <div
                                class="card border-<%= bucket.colour %> shadow-sm h-100"
                            >
                                <div
                                    class="card-header text-bg-<%= bucket.colour %>"
                                >
                                    <h2 class="h5 mb-0">
                                        <%= bucket.title %>
                                    </h2>
                                </div>

                                <div class="card-body">

                                    <form
                                        action="/retrospective/add"
                                        method="POST"
                                        class="mb-4"
                                    >
                                        <input
                                            type="hidden"
                                            name="bucketType"
                                            value="<%= bucket.type %>"
                                        >

                                        <textarea
                                            class="form-control mb-2"
                                            name="content"
                                            rows="3"
                                            maxlength="1000"
                                            placeholder="Write your reflection..."
                                            required
                                        ></textarea>

                                        <button
                                            type="submit"
                                            class="btn btn-<%= bucket.colour %> w-100"
                                        >
                                            Add Entry
                                        </button>
                                    </form>

                                    <% if (bucket.items.length === 0) { %>
                                        <div class="alert alert-light border">
                                            No entries yet.
                                        </div>
                                    <% } %>

                                    <% bucket.items.forEach(function (item) { %>
                                        <%
                                            const canManage =
                                                currentProjectRole ===
                                                "Project Leader" ||
                                                Number(item.userId) ===
                                                Number(currentUser.userId);
                                        %>

                                        <div class="card bg-light mb-3">
                                            <div class="card-body">

                                                <p>
                                                    <%= item.content %>
                                                </p>

                                                <p class="small text-muted">
                                                    Added by
                                                    <%= item.userName %>
                                                </p>

                                                <% if (canManage) { %>
                                                    <div class="d-flex gap-2">
                                                        <button
                                                            type="button"
                                                            class="btn btn-sm btn-outline-primary"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#editItem<%= item.retrospectiveId %>"
                                                        >
                                                            Edit
                                                        </button>

                                                        <form
                                                            action="/retrospective/<%= item.retrospectiveId %>/delete"
                                                            method="POST"
                                                            onsubmit="return confirm('Delete this entry?');"
                                                        >
                                                            <button
                                                                type="submit"
                                                                class="btn btn-sm btn-outline-danger"
                                                            >
                                                                Delete
                                                            </button>
                                                        </form>
                                                    </div>
                                                <% } %>

                                            </div>
                                        </div>

                                        <div
                                            class="modal fade"
                                            id="editItem<%= item.retrospectiveId %>"
                                            tabindex="-1"
                                            aria-hidden="true"
                                        >
                                            <div class="modal-dialog">
                                                <div class="modal-content">

                                                    <form
                                                        action="/retrospective/<%= item.retrospectiveId %>/edit"
                                                        method="POST"
                                                    >
                                                        <div class="modal-header">
                                                            <h2 class="modal-title fs-5">
                                                                Edit Entry
                                                            </h2>

                                                            <button
                                                                type="button"
                                                                class="btn-close"
                                                                data-bs-dismiss="modal"
                                                                aria-label="Close"
                                                            ></button>
                                                        </div>

                                                        <div class="modal-body">
                                                            <div class="mb-3">
                                                                <label class="form-label">
                                                                    Bucket
                                                                </label>

                                                                <select
                                                                    class="form-select"
                                                                    name="bucketType"
                                                                    required
                                                                >
                                                                    <option
                                                                        value="went_well"
                                                                        <%= item.bucketType === "went_well" ? "selected" : "" %>
                                                                    >
                                                                        What Went Well
                                                                    </option>

                                                                    <option
                                                                        value="improvement"
                                                                        <%= item.bucketType === "improvement" ? "selected" : "" %>
                                                                    >
                                                                        What Can Be Improved
                                                                    </option>

                                                                    <option
                                                                        value="thanks"
                                                                        <%= item.bucketType === "thanks" ? "selected" : "" %>
                                                                    >
                                                                        Say Thanks
                                                                    </option>
                                                                </select>
                                                            </div>

                                                            <div>
                                                                <label class="form-label">
                                                                    Content
                                                                </label>

                                                                <textarea
                                                                    class="form-control"
                                                                    name="content"
                                                                    rows="4"
                                                                    maxlength="1000"
                                                                    required
                                                                ><%= item.content %></textarea>
                                                            </div>
                                                        </div>

                                                        <div class="modal-footer">
                                                            <button
                                                                type="button"
                                                                class="btn btn-outline-secondary"
                                                                data-bs-dismiss="modal"
                                                            >
                                                                Cancel
                                                            </button>

                                                            <button
                                                                type="submit"
                                                                class="btn btn-primary"
                                                            >
                                                                Save Changes
                                                            </button>
                                                        </div>
                                                    </form>

                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>

                                </div>
                            </div>

                        </div>
                    <% }); %>

                </div>

            </main>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
</body>
</html>
