<!DOCTYPE html>
<%# Displays project risks, levels, status and actions. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Risk Register</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/resources/styles.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <div class="container-fluid">
        <div class="row">

            <%- include("partials/sidebar") %>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">

                <%- include("partials/messages") %>

                <div
                    class="d-flex justify-content-between align-items-center mb-4"
                >
                    <div>
                        <h1 class="h2 mb-1">
                            Risk Register
                        </h1>
                        <p class="text-muted mb-0">
                            Risks tracked for the selected project.
                        </p>
                    </div>
                    <a href="/risks/add" class="btn btn-primary">
                        Add Risk
                    </a>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6 col-lg">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <p class="text-muted mb-1">Total</p>
                                <h2 class="fw-bold mb-0"><%= summary.total %></h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <p class="text-muted mb-1">Open</p>
                                <h2 class="fw-bold mb-0"><%= summary.open %></h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <p class="text-muted mb-1">Monitoring</p>
                                <h2 class="fw-bold mb-0"><%= summary.monitoring %></h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <p class="text-muted mb-1">Resolved</p>
                                <h2 class="fw-bold mb-0"><%= summary.resolved %></h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg">
                        <div class="card border-danger shadow-sm h-100">
                            <div class="card-body">
                                <p class="text-danger mb-1">Critical Active</p>
                                <h2 class="fw-bold text-danger mb-0"><%= summary.critical %></h2>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        <% if (risks.length === 0) { %>
                            <div class="alert alert-light border m-3">
                                No risks have been recorded for this project.
                            </div>
                        <% } else { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Risk</th>
                                            <th>Probability</th>
                                            <th>Impact</th>
                                            <th>Rating</th>
                                            <th>Contingency Plan</th>
                                            <th>Status</th>
                                            <th>Reported By</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% risks.forEach(function (risk) { %>
                                            <tr>
                                                <td>
                                                    <strong><%= risk.riskTitle %></strong>
                                                    <div class="small text-muted"><%= risk.description %></div>
                                                </td>
                                                <td><%= risk.probability %></td>
                                                <td><%= risk.impact %></td>
                                                <td>
                                                    <span class="badge <%= risk.riskLevel === 'Critical' ? 'text-bg-danger' : risk.riskLevel === 'High' ? 'text-bg-warning' : risk.riskLevel === 'Medium' ? 'text-bg-info' : 'text-bg-success' %>">
                                                        <%= risk.riskLevel %>
                                                    </span>
                                                    <div class="small text-muted">Score: <%= risk.riskScore %></div>
                                                </td>
                                                <td><%= risk.contingencyPlan %></td>
                                                <td>
                                                    <span class="badge <%= risk.status === 'Resolved' ? 'text-bg-success' : risk.status === 'Monitoring' ? 'text-bg-warning' : 'text-bg-danger' %>">
                                                        <%= risk.status %>
                                                    </span>
                                                </td>
                                                <td><%= risk.reporterName %></td>
                                                <td>
                                                    <% if (currentProjectRole === "Project Leader") { %>
                                                        <div class="d-flex flex-wrap gap-1">
                                                            <a href="/risks/<%= risk.riskId %>/edit" class="btn btn-sm btn-outline-secondary">
                                                                Edit
                                                            </a>
                                                            <% if (risk.status !== "Resolved") { %>
                                                                <form action="/risks/<%= risk.riskId %>/resolve" method="POST" class="d-inline">
                                                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                                                        Resolve
                                                                    </button>
                                                                </form>
                                                            <% } %>
                                                            <form action="/risks/<%= risk.riskId %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this risk?');">
                                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                    Delete
                                                                </button>
                                                            </form>
                                                        </div>
                                                    <% } else { %>
                                                        <span class="small text-muted">View only</span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>
                </div>

            </main>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
</body>
</html>
