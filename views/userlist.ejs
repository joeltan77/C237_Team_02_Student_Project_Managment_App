<!DOCTYPE html>
<%# Displays all members of the selected project. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Members</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>
    <div class="container-fluid"><div class="row">
        <%- include("partials/sidebar") %>
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <%- include("partials/messages") %>
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                <div>
                    <h1 class="h2 mb-1">Project Members</h1>
                    <p class="text-muted mb-0">People working on <%= selectedProject.projectName %>.</p>
                </div>
                <% if (currentProjectRole === "Project Leader") { %>
                    <a href="/dashboard" class="btn btn-primary">Add Member from Dashboard</a>
                <% } %>
            </div>

            <% if (members.length === 0) { %>
                <div class="alert alert-info">No members were found for this project.</div>
            <% } else { %>
                <div class="row g-4">
                    <% members.forEach(function (member) { %>
                        <div class="col-md-6 col-xl-4">
                            <article class="card h-100">
                                <div class="card-body text-center p-4">
                                    <img src="<%= member.profilePicture || '/images/profile-pictures/default-profile.svg' %>" alt="<%= member.name %>" class="rounded-circle border shadow-sm mb-3" width="88" height="88" style="object-fit: cover;">
                                    <h2 class="h5 mb-1"><%= member.name %></h2>
                                    <p class="text-muted small mb-2">@<%= member.username %></p>
                                    <span class="badge <%= member.role === 'Project Leader' ? 'text-bg-primary' : 'text-bg-secondary' %>"><%= member.role %></span>
                                    <hr>
                                    <p class="small mb-1"><strong>Email:</strong> <%= member.email %></p>
                                    <p class="small mb-1"><strong>Diploma:</strong> <%= member.diploma || '-' %></p>
                                    <p class="small mb-2"><strong>Year/Semester:</strong> <%= member.yearSemester || '-' %></p>
                                    <p class="text-muted small mb-0"><%= member.bio || 'No bio added.' %></p>
                                </div>
                            </article>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </main>
    </div></div>
    <%- include("partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
