<!DOCTYPE html>
<%# Form for updating resource details or replacing its file. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Edit Resource</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/resources/styles.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <div class="container-fluid">
        <div class="row">

            <%- include("partials/sidebar") %>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">

                <%- include("partials/messages") %>

                <div class="mb-4">
                    <h1 class="h2 mb-1">
                        Edit Resource
                    </h1>
                    <p class="text-muted mb-0">
                        Update the resource details, or replace the file.
                    </p>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <form action="/resources/<%= resource.resourceId %>/edit" method="POST" enctype="multipart/form-data">
                            <div class="row g-3">

                                <div class="col-12">
                                    <label for="resourceName" class="form-label">
                                        Resource Name
                                    </label>
                                    <input
                                        type="text"
                                        class="form-control"
                                        id="resourceName"
                                        name="resourceName"
                                        value="<%= resource.resourceName %>"
                                        required
                                    >
                                </div>

                                <div class="col-12">
                                    <label for="description" class="form-label">
                                        Description
                                    </label>
                                    <textarea
                                        class="form-control"
                                        id="description"
                                        name="description"
                                        rows="4"
                                    ><%= resource.description || "" %></textarea>
                                </div>

                                <div class="col-12">
                                    <label class="form-label">
                                        Current File
                                    </label>
                                    <input class="form-control" value="<%= resource.fileName %>" readonly>
                                </div>

                                <div class="col-12">
                                    <label for="resourceFile" class="form-label">
                                        Replace File (optional)
                                    </label>
                                    <input
                                        type="file"
                                        class="form-control"
                                        id="resourceFile"
                                        name="resourceFile"
                                    >
                                </div>

                                <div class="col-12">
                                    <div class="d-flex gap-2">
                                        <button type="submit" class="btn btn-primary">
                                            Save Changes
                                        </button>
                                        <a href="/resources" class="btn btn-outline-secondary">
                                            Cancel
                                        </a>
                                    </div>
                                </div>

                            </div>
                        </form>

                    </div>
                </div>

            </main>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
</body>
</html>
