<!DOCTYPE html>
<%# Welcome page for selecting and managing projects. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to ProjectPulse</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>

    <main class="container py-4 py-lg-5 project-home">
        <%- include("partials/messages") %>

        <section class="welcome-panel mb-4">
            <div>
                <p class="welcome-label mb-2">PROJECTPULSE WORKSPACE</p>
                <h1 class="display-6 mb-2">Welcome back, <%= currentUser.name %>!</h1>
                <p class="mb-0 text-muted">Choose a project to continue managing your tasks, meetings and team progress.</p>
            </div>
            <div class="welcome-count d-none d-md-flex">
                <strong><%= userProjects.length %></strong>
                <span>Active <%= userProjects.length === 1 ? "project" : "projects" %></span>
            </div>
        </section>

        <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
            <div>
                <h2 class="h3 mb-1">Your projects</h2>
                <p class="text-muted mb-0">Your access is based on your role in each project.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a href="/archivedprojects" class="btn btn-sm btn-outline-secondary">Archived Projects</a>
                <a href="/addproject" class="btn btn-sm btn-primary">+ Add Project</a>
            </div>
        </div>

        <% if (userProjects.length === 0) { %>
            <div class="empty-projects text-center">
                <div class="empty-projects-icon">+</div>
                <h2 class="h4">Create your first project</h2>
                <p class="text-muted">You are not currently assigned to an active project.</p>
                <a href="/addproject" class="btn btn-primary">Add Project</a>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% userProjects.forEach(function (project) { %>
                    <div class="col-md-6">
                        <article class="card project-card h-100">
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <p class="project-card-label mb-1">ACTIVE PROJECT</p>
                                        <h3 class="h4 mb-0"><%= project.projectName %></h3>
                                    </div>
                                    <span class="badge <%= project.role === 'Project Leader' ? 'text-bg-primary' : 'text-bg-secondary' %>"><%= project.role %></span>
                                </div>

                                <p class="text-muted project-description"><%= project.description || "No description provided." %></p>

                                <div class="project-meta mt-auto">
                                    <div><span>Due date</span><strong><%= project.endDate ? new Date(project.endDate).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' }) : 'Not set' %></strong></div>
                                    <div><span>Status</span><strong><%= project.status || "Active" %></strong></div>
                                </div>

                                <div class="project-actions mt-4">
                                    <form action="/projects/select" method="POST">
                                        <input type="hidden" name="projectId" value="<%= project.projectId %>">
                                        <button type="submit" class="btn btn-primary">Open Project</button>
                                    </form>
                                    <a href="/editproject/<%= project.projectId %>" class="btn btn-outline-secondary">Edit</a>
                                    <% if (project.role === "Project Leader") { %>
                                        <form action="/archiveproject/<%= project.projectId %>" method="POST">
                                            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Archive this project?');">Archive</button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </article>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
