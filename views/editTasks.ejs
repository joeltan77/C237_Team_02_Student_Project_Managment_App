<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Task</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>
    <div class="container-fluid"><div class="row">
        <%- include("partials/sidebar") %>
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
            <%- include("partials/messages") %>
            <h1 class="h2 mb-4">Edit Task</h1>
            <div class="card border-0 shadow-sm"><div class="card-body p-4">
                <form action="/tasks/<%= task.taskId %>/edit" method="POST"><div class="row g-3">
                    <div class="col-md-8">
                        <label for="taskName" class="form-label">Task Name</label>
                        <input id="taskName" name="taskName" class="form-control" value="<%= task.taskName %>" required>
                    </div>
                    <div class="col-md-4">
                        <label for="assignedUserId" class="form-label">Assigned Member</label>
                        <select id="assignedUserId" name="assignedUserId" class="form-select" required>
                            <% members.forEach(function (member) { %>
                                <option value="<%= member.userId %>" <%= Number(task.assignedUserId) === Number(member.userId) ? "selected" : "" %>><%= member.name %> - <%= member.role %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-12">
                        <label for="description" class="form-label">Description</label>
                        <textarea id="description" name="description" class="form-control" rows="4"><%= task.description || "" %></textarea>
                    </div>
                    <div class="col-md-4">
                        <label for="priority" class="form-label">Priority</label>
                        <select id="priority" name="priority" class="form-select" required>
                            <% ["Low", "Medium", "High"].forEach(function (priority) { %><option value="<%= priority %>" <%= task.priority === priority ? "selected" : "" %>><%= priority %></option><% }); %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="status" class="form-label">Status</label>
                        <select id="status" name="status" class="form-select" required>
                            <% ["Not Started", "In Progress", "Completed"].forEach(function (status) { %><option value="<%= status %>" <%= task.status === status ? "selected" : "" %>><%= status %></option><% }); %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="dueDate" class="form-label">Due Date</label>
                        <input type="date" id="dueDate" name="dueDate" class="form-control" value="<%= task.dueDate %>" required>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Update Task</button>
                        <a href="/tasks/<%= task.taskId %>" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div></form>
            </div></div>
        </main>
    </div></div>
    <%- include("partials/footer") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
