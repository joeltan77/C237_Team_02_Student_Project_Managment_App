<!DOCTYPE html>
<%# Lists archived projects with restore and delete actions. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Select Project</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/resources/styles.css">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <main class="container py-5">

        <%- include("partials/messages") %>

        <div class="mb-4">
            <h1 class="h2 mb-1">
                Select an Archived Project
            </h1>

            <p class="text-muted mb-0">
                These archived projects consists of scrapped or completed projects. 
            </p>
        </div>

        <div class="row g-4">

            <% if (userProjects.length === 0) { %>
                <div class="col-12">
                    <div class="alert alert-warning">
                        You do not have any archived projects.
                    </div>
                </div>
            <% } %>

            <% userProjects.forEach(function (project) { %>
                <div class="col-md-6">

                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">

                            <div
                                class="d-flex justify-content-between align-items-start gap-3"
                            >
                                <div>
                                    <h2 class="h4">
                                        <%= project.projectName %>
                                    </h2>

                                    <p class="text-muted">
                                        <%= project.description %>
                                    </p>
                                    <p>
                                        <strong>Due Date:</strong>
                                        <%= project.endDate ? new Date(project.endDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 'N/A' %>
                                    </p>
                                    <p>
                                        <strong>Project status:</strong>
                                        <%= project.status %>
                                    </p>
                                </div>

                                <span
                                    class="badge <%= project.role === 'Project Leader' ? 'text-bg-primary' : 'text-bg-secondary' %>"
                                >
                                    <%= project.role %>
                                </span>
                            </div>

                            <form
                                action="/projects/select"
                                method="POST"
                                class="mt-3"
                            >
                                <input
                                    type="hidden"
                                    name="projectId"
                                    value="<%= project.projectId %>"
                                >

                                <button
                                    type="submit"
                                    class="btn btn-primary"
                                >
                                    Open Project
                                </button>
                            </form>
                            <br>
                            <% if (project.role === "Project Leader") { %>
                                <div class="d-flex flex-wrap gap-2">
                                    <form action="/restoreproject/<%= project.projectId %>" method="POST">
                                        <button type="submit" class="btn btn-success">Restore Project</button>
                                    </form>
                                    <form action="/deleteproject/<%= project.projectId %>" method="POST">
                                        <button type="submit" class="btn btn-danger" onclick="return confirm('Permanently delete this project?');">Delete Project</button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }); %>
            <button onclick="window.location.href='/projects';" class="btn btn-danger">Return to Active Projects</button>
        </div>
    </main>
    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
</body>
</html>
