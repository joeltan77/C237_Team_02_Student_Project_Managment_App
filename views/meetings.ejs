<!DOCTYPE html>
<%# Lists meetings for the selected project. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Meetings</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/resources/styles.css">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <div class="container-fluid">
        <div class="row">

            <%- include("partials/sidebar") %>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">

                <%- include("partials/messages") %>

                <div
                    class="d-flex justify-content-between align-items-center mb-4"
                >
                    <div>
                        <h1 class="h2 mb-1">
                            Meetings
                        </h1>

                        <p class="text-muted mb-0">
                            Meetings for the selected project.
                        </p>
                    </div>

                    <% if (currentProjectRole === "Project Leader") { %>
                        <a
                            href="/meetings/add"
                            class="btn btn-primary"
                        >
                            Schedule Meeting
                        </a>
                    <% } %>
                </div>

                <div class="row g-4">

                    <% if (meetings.length === 0) { %>
                        <div class="col-12">
                            <div class="alert alert-light border">
                                No meetings have been scheduled.
                            </div>
                        </div>
                    <% } %>

                    <% meetings.forEach(function (meeting) { %>
                        <div class="col-md-6 col-xl-4">

                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body">

                                    <h2 class="h5">
                                        <%= meeting.meetingTitle %>
                                    </h2>

                                    <p class="text-muted mb-1">
                                        <%= new Date(meeting.meetingDate).toLocaleDateString("en-SG") %>
                                        at
                                        <%= meeting.meetingTime %>
                                    </p>

                                    <p class="text-muted">
                                        <%= meeting.location || "No location provided" %>
                                    </p>

                                    <div class="d-flex flex-wrap gap-2">
                                        <a
                                            href="/meetings/<%= meeting.meetingId %>"
                                            class="btn btn-sm btn-outline-primary"
                                        >
                                            View
                                        </a>

                                        <% if (currentProjectRole === "Project Leader") { %>
                                            <a
                                                href="/meetings/<%= meeting.meetingId %>/edit"
                                                class="btn btn-sm btn-outline-secondary"
                                            >
                                                Edit
                                            </a>

                                            <form
                                                action="/meetings/<%= meeting.meetingId %>/delete"
                                                method="POST"
                                                onsubmit="return confirm('Delete this meeting?');"
                                            >
                                                <button
                                                    type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                >
                                                    Delete
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>

                                </div>
                            </div>

                        </div>
                    <% }); %>

                </div>

            </main>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
</body>
</html>
