<!DOCTYPE html>
<html>
<head>
    <title>My Achievements</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">ProjectPulse</a>
            <div>
                <span class="text-white me-3"><%= user.name %></span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h2>My Achievements</h2>
        <p class="text-muted">Complete tasks to earn badges!</p>
        
        <div class="row mt-4">
            <% if (achievements.length === 0) { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted">No achievements yet. Complete tasks to earn badges!</p>
                </div>
            <% } else { %>
                <% achievements.forEach(achievement => { %>
                    <div class="col-md-3 mb-3">
                        <div class="card text-center">
                            <div class="card-body">
                                <h3><%= achievement.label %></h3>
                                <small class="text-muted">Earned: <%= new Date(achievement.earned_at).toLocaleDateString() %></small>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
        
        <div class="mt-4">
            <a href="/dashboard" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>
</body>
</html>