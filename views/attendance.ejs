<!DOCTYPE html>
<%# Records each project member's meeting attendance. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Meeting Attendance</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/resources/styles.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <div class="container-fluid">
        <div class="row">

            <%- include("partials/sidebar") %>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">

                <%- include("partials/messages") %>

                <div class="mb-4">
                    <h1 class="h2 mb-1">
                        Meeting Attendance
                    </h1>
                    <p class="text-muted mb-0">
                        <%= meeting.meetingTitle %> —
                        <%= new Date(meeting.meetingDate).toLocaleDateString("en-SG") %>
                        <% if (meeting.location) { %>
                            · <%= meeting.location %>
                        <% } %>
                    </p>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <form action="/meetings/<%= meeting.meetingId %>/attendance" method="POST">
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                        <tr>
                                            <th>Member</th>
                                            <th width="220">Attendance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% members.forEach(function (member) { %>
                                            <tr>
                                                <td><%= member.name %></td>
                                                <td>
                                                    <select name="attendance_<%= member.userId %>" class="form-select">
                                                        <option value="Present" <%= member.attendanceStatus === "Present" ? "selected" : "" %>>Present</option>
                                                        <option value="Late" <%= member.attendanceStatus === "Late" ? "selected" : "" %>>Late</option>
                                                        <option value="Absent" <%= member.attendanceStatus === "Absent" ? "selected" : "" %>>Absent</option>
                                                    </select>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>

                            <div class="d-flex gap-2 mt-3">
                                <button type="submit" class="btn btn-primary">
                                    Save Attendance
                                </button>
                                <a href="/meetings/<%= meeting.meetingId %>" class="btn btn-outline-secondary">
                                    Cancel
                                </a>
                            </div>
                        </form>

                    </div>
                </div>

            </main>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
</body>
</html>
