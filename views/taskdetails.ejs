<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Task Details</title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="/resources/styles.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>

<body class="bg-light">

    <%- include("partials/navbar") %>

    <div class="container-fluid">
        <div class="row">

            <%- include("partials/sidebar") %>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">

                <%- include("partials/messages") %>

                <div
                    class="d-flex justify-content-between align-items-center mb-4"
                >
                    <div>
                        <h1 class="h2 mb-1">
                            Task Details
                        </h1>

                        <p class="text-muted mb-0">
                            View the selected task.
                        </p>
                    </div>

                    <% if (currentProjectRole === "Project Leader") { %>
                        <a
                            href="/tasks/<%= task.taskId %>/edit"
                            class="btn btn-primary"
                        >
                            Edit Task
                        </a>
                    <% } %>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <h2 class="h4 mb-4">
                            <%= task.taskName %>
                        </h2>

                        <div class="row g-4">

                            <div class="col-md-6">
                                <strong>Assigned To</strong>
                                <p class="mb-0">
                                    <%= assignedUser ? assignedUser.name : "Unassigned" %>
                                </p>
                            </div>

                            <div class="col-md-3">
                                <strong>Priority</strong>
                                <p class="mb-0">
                                    <%= task.priority %>
                                </p>
                            </div>

                            <div class="col-md-3">
                                <strong>Status</strong>
                                <p class="mb-0">
                                    <%= task.status %>
                                </p>
                            </div>

                            <div class="col-md-6">
                                <strong>Due Date</strong>
                                <p class="mb-0">
                                    <%= new Date(task.dueDate).toLocaleDateString("en-SG") %>
                                </p>
                            </div>

                            <div class="col-12">
                                <strong>Description</strong>
                                <p class="mb-0">
                                    <%= task.description || "No description provided." %>
                                </p>
                            </div>

                        </div>

                        <div class="mt-4">
                            <a
                                href="/tasks"
                                class="btn btn-outline-secondary"
                            >
                                Back to Tasks
                            </a>
                        </div>

                    </div>
                </div>

                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-white py-3">
                        <h2 class="h5 mb-0">Comments</h2>
                    </div>
                    <div class="card-body">

                        <% if (comments.length === 0) { %>
                            <p class="text-muted">No comments yet.</p>
                        <% } else { %>
                            <% comments.forEach(function (comment) { %>
                                <div class="border-bottom pb-2 mb-2">
                                    <div class="d-flex justify-content-between">
                                        <strong><%= comment.userName %></strong>
                                        <small class="text-muted"><%= new Date(comment.createdAt).toLocaleString("en-SG") %></small>
                                    </div>
                                    <p class="mb-0"><%= comment.comment %></p>
                                </div>
                            <% }); %>
                        <% } %>

                        <form action="/tasks/<%= task.taskId %>/comment" method="POST" class="mt-3">
                            <div class="input-group">
                                <input
                                    type="text"
                                    class="form-control"
                                    name="comment"
                                    placeholder="Add a comment..."
                                    required
                                >
                                <button type="submit" class="btn btn-primary">
                                    Post
                                </button>
                            </div>
                        </form>

                    </div>
                </div>

            </main>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    ></script>
</body>
</html>