<%
    const navbarUser =
        typeof currentUser !== "undefined"
            ? currentUser
            : null;

    const navbarProject =
        typeof selectedProject !== "undefined"
            ? selectedProject
            : null;

    const navbarRole =
        typeof currentProjectRole !== "undefined"
            ? currentProjectRole
            : null;
%>

<nav class="navbar navbar-dark bg-primary sticky-top shadow-sm">
    <div class="container-fluid">

        <% if (navbarUser) { %>
            <button
                class="navbar-toggler d-md-none me-2"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#sidebarMenu"
                aria-controls="sidebarMenu"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
        <% } %>

        <a
            class="navbar-brand fw-bold"
            href="<%= navbarProject ? '/dashboard' : '/projects' %>"
        >
            Student Project Manager
        </a>

        <% if (navbarUser) { %>
            <div class="ms-auto d-flex align-items-center gap-3">

                <% if (navbarProject) { %>
                    <div class="text-end d-none d-lg-block text-white">
                        <div class="small fw-semibold">
                            <%= navbarProject.projectName %>
                        </div>

                        <div class="small opacity-75">
                            <%= navbarRole %>
                        </div>
                    </div>
                <% } %>

                <a
                    href="/profile"
                    class="text-decoration-none d-flex align-items-center gap-2 text-white"
                >
                    <img
                        src="<%= navbarUser.profilePicture || '/images/profile-pictures/default-profile.svg' %>"
                        alt="Profile picture"
                        class="rounded-circle border border-white"
                        width="40"
                        height="40"
                        style="object-fit: cover;"
                    >

                    <span class="d-none d-sm-inline">
                        <%= navbarUser.name %>
                    </span>
                </a>

            </div>
        <% } %>

    </div>
</nav>
