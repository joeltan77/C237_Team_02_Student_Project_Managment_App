<!DOCTYPE html>
<%# Confirms before ending the current login session. %>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logout</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/resources/styles.css">
</head>
<body class="bg-light">
    <%- include("partials/navbar") %>

    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-5">
                <div class="card shadow-sm">
                    <div class="card-header bg-danger text-white">
                        <h1 class="h4 mb-0 text-white">Logout Confirmation</h1>
                    </div>
                    <div class="card-body p-4 text-center">
                        <h2 class="h5">Are you sure you want to log out?</h2>
                        <p class="text-muted">Your current login session will end.</p>
                        <form action="/logout" method="POST" class="d-flex justify-content-center gap-2">
                            <button type="submit" class="btn btn-danger">Yes, Logout</button>
                            <a href="<%= selectedProject ? '/dashboard' : '/projects' %>" class="btn btn-outline-secondary">Cancel</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
